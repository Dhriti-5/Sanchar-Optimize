# Project-level gitignore for Sanchar-Optimize

# Test files
test_*.py
test_*.txt
test_*.html
check_*.py
**/test/
**/tests/

# Logs
*.log
logs/

# Python cache
__pycache__/
*.py[cod]

# Virtual environments
venv/
.venv/
ENV/
env/

# Environment files
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build outputs
dist/
build/
*.egg-info/
